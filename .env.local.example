# Copy to .env.local (Next.js loads it automatically).

# Backend API (Flask). With ngrok, this must be the tunnel to port 5000 — not the Next.js site (3000).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5000

# Investor / EC2 demo: no Firebase; matches backend DISABLE_API_AUTH=true
# NEXT_PUBLIC_INVESTOR_MODE=true

# Append apiFetch round-trips to backend/logs/clairvyn-bridge.log (requires CLAIRVYN_BRIDGE_CLIENT_LOG on Flask)
# NEXT_PUBLIC_BRIDGE_LOG=true
